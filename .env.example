# Copy to .env and adjust. .env is gitignored and safe for local secrets.

# App
SECRET_KEY=change-me-in-production
DEBUG=false
ENV=development

# Server
HOST=0.0.0.0
PORT=8000

# Optional: override output directories (leave empty to use defaults)
# COMPRESSED_OUTPUT_DIR=
# DECOMPRESSED_OUTPUT_DIR=
# STL_COMPRESSED_DIR=
# STL_DECOMPRESSED_DIR=

# CORS (comma-separated origins; * = allow all)
CORS_ORIGINS=*

# Optional: API key for protected routes (leave empty to disable)
# API_KEY=
